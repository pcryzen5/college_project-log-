<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script  type="text/javascript">
    $(document).ready(function () {
        $('.category_container .dropdown_menu_arrow').on("click", function () {
            var selected = $(this).parents(".category_container").find(".category_urls_list").hasClass('dropdown_selected');
            $(".category_container .category_urls_list").removeClass('dropdown_selected');
            $('.category_container .dropdown_menu_arrow').text('keyboard_arrow_right');
            if(selected){
                $(this).parents(".category_container").find(".category_urls_list").removeClass('dropdown_selected');
                $(this).text('keyboard_arrow_right');
            }else {
                $(this).parents(".category_container").find(".category_urls_list").addClass('dropdown_selected');
                $(this).text('keyboard_arrow_down');
            }
        });
    });
</script>    <div class="flsbottom">
