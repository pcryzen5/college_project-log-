<script type="text/plain" class="flsjsdeferprocess">
    $(document).ready(function () {
        menu_toggler();
        show_hide_nav_submenu();
    });
    function menu_toggler() {
        $(".nav-item-toggler-button").on("click", function (event) {
            event.preventDefault();
            var parent = $(this).parent();
            if (parent.hasClass('nav-item-toggler-active')) {
                parent.removeClass('nav-item-toggler-active');
                $('.nav-item-my-account, .nav-item-my-projects').css('pointer-events', 'auto');
                $('.nav-item-toggler-icon').text('menu');
            } else {
                parent.addClass('nav-item-toggler-active');
                $('.nav-item-my-account, .nav-item-my-projects').css('pointer-events', 'none');
                $('.nav-item-toggler-icon').text('close');
            }
        });
    }
    function show_hide_nav_submenu() {
        $(".navbar-nav-has-submenu > a").click(function (event) {
            event.preventDefault();
            var parent = $(this).parent();
            var selectedNavItem = $(this);
            if (parent.hasClass('open')) {
                parent.removeClass('open').find('.navbar-nav-has-submenu-icon').text('expand_more');
                selectedNavItem.removeClass('font-bold');
            } else {
                $('.navbar-nav-has-submenu.open').removeClass('open').find('.navbar-nav-has-submenu-icon').text('expand_more').end().find('.dropdown-item').removeClass('font-bold');
                parent.addClass('open').find('.navbar-nav-has-submenu-icon').text('expand_less');
                selectedNavItem.addClass('font-bold');
            }
        });
    }
</script>


